---
import Base from "./Base.astro";
import Sidebar from "@components/Sidebar.astro";
import Vertlist from "@components/vertlist/Vertlist.astro";
import VertlistItem from "@components/vertlist/VertlistItem.astro";
import VertlistHeader from "@components/vertlist/VertlistHeader.astro";
import { sidebarLinks } from "@data/sidebar";
import Page from "@/components/page/Page.astro";

const pathname = new URL(Astro.request.url).pathname;
// Normalize pathname by removing trailing slash for consistent comparison
const normalizedPathname = pathname.endsWith('/') && pathname.length > 1 
    ? pathname.slice(0, -1) 
    : pathname;

const { 
    title = "Crafted UI Docs", 
    description = "Documentation for the Crafted UI component library."
} = Astro.props;
---
<Base title={title} description={description}>
    <div class="lg:flex lg:gap-10 px-4 lg:px-6">
        <div class="hidden lg:block">
            <Sidebar className="space-y-8">
                { sidebarLinks.map((sect) => (
                    <Vertlist>
                        <VertlistHeader>{ sect.title }</VertlistHeader>
                            { sect.items.map((item) => (
                                <VertlistItem>
                                    <a href={item.href} class={normalizedPathname === item.href ? "active" : ""}>{item.title}</a>
                                </VertlistItem>
                            ))}
                    </Vertlist>                       
                ))}
            </Sidebar>
        </div>
        <Page title={ title } subtitle={ description }>
            <slot />
        </Page>
    </div>
</Base>