---
import { classNames } from "../utils/classNames"

interface Props {
    title?: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---
<div class="pb-3 space-y-2 border-b border-gray-200">
    <h3 class="text-2xl font-bold tracking-tight">
        { !!title 
            ? title 
            : <slot /> 
        }
    </h3>
    {
        subtitle && (
            <p class="text-gray-500">
                {subtitle}
            </p>
        )
    }
</div>