---
import { classNames } from "../utils/classNames"

interface Props {
    type?: string;
    href?: string;
}

const { type = 'button', href } = Astro.props;

const buttonType = (type === 'link') ? 'button' : type as ("reset" | "submit" | "button" | null | undefined);
---
{ 
    type === 'link'
    ? (
        <a  href={href}
            class={classNames(
                "border-transparent text-white bg-green-700 hover:bg-green-800 focus:ring-green-300",
                "rounded-md",
                "border px-2 py-2",
                "text-sm font-semibold shadow-sm",
                "focus:outline-none focus:ring-2 focus:ring-offset-2"
            )}>
            <slot />
        </a>
    )
    : (
        <button type={buttonType}
                class={classNames(
                "border-transparent text-white bg-green-700 hover:bg-green-800 focus:ring-green-300",
                "rounded-md",
                "border px-4 py-2",
                "text-sm font-semibold shadow-sm",
                "focus:outline-none focus:ring-2 focus:ring-offset-2"
            )}>
            <slot />
        </button>
    )
}