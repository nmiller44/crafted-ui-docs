---
import { classNames } from "@/utils/classNames";
import DescListLabel from "./DescListLabel.astro";

export interface Props {
    label?: string;
    value?: string;
    class?: string;
}

const { label, value, class: className, ...props } = Astro.props;
const hasSlot = Astro.slots.has('default');
---

<div class={classNames("space-y-2", "col-span-full", className)} {...props}>
    {label && <DescListLabel>{label}</DescListLabel>}
    <dd class="text-sm text-foreground leading-6">
        {value || (hasSlot && <slot />)}
    </dd>
</div>
