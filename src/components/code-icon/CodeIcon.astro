---
import { classNames } from "../../utils/classNames";
import Card from "../card/Card.astro";
import CopyIcon from "../icons/CopyIcon.astro";

interface Props {
  iconName: string;
  icon: any;
  class?: string;
}

const { iconName, icon: IconComponent, class: className } = Astro.props;
---

<div
  class={classNames("group cursor-pointer transition-transform hover:scale-105", className)}
  data-icon-name={iconName}
>
  <Card className="h-full relative">
    <div>
      <div class="flex flex-col items-center justify-center p-6 min-h-32">
        <div class="mb-3 text-muted-foreground group-hover:text-foreground transition-colors flex items-center justify-center">
          <IconComponent class="size-8" />
        </div>
        <div class="text-xs font-medium text-center text-muted-foreground group-hover:text-foreground transition-colors">
          {iconName}
        </div>
      </div>
      <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity text-muted-foreground">
        <CopyIcon width={14} height={14} />
      </div>
    </div>
  </Card>
</div>

<script is:inline define:vars={{ iconName }}>
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll("[data-icon-name]");
    
    cards.forEach((card) => {
      card.addEventListener("click", async () => {
        const name = card.getAttribute("data-icon-name");
        const code = `<${name} />`;
        
        try {
          await navigator.clipboard.writeText(code);
          
          // Create toast notification
          const toast = document.createElement("div");
          toast.className = "fixed bottom-4 right-4 bg-primary text-primary-foreground px-4 py-2 rounded-md shadow-lg z-50 animate-in fade-in-0 slide-in-from-bottom-2 duration-300";
          toast.textContent = "Copied!";
          document.body.appendChild(toast);
          
          // Remove toast after 2 seconds
          setTimeout(() => {
            toast.className += " animate-out fade-out-0 slide-out-to-bottom-2 duration-300";
            setTimeout(() => {
              toast.remove();
            }, 300);
          }, 2000);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });
    });
  });
</script>
