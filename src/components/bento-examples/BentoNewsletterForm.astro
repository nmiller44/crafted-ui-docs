---
import { classNames } from "../../utils/classNames"
import BentoCard from "../bento/BentoCard.astro";
import Field from "../field/Field.astro";
import Input from "../input/Input.astro";
import Button from "../button/Button.astro";

interface Props {
    className?: string;
}

const { 
    className
 } = Astro.props;
---
<BentoCard className={classNames("space-y-6", className)}>
    <div class="flex items-center space-x-3">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-primary to-secondary">
            <svg class="w-6 h-6 text-background" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
        </div>
        <div>
            <h3 class="font-semibold text-lg text-foreground">Newsletter Signup</h3>
            <p class="text-sm text-muted-foreground">Stay updated with our latest news and updates</p>
        </div>
    </div>

    <form class="space-y-4">
        <Field label="Full Name">
            <Input placeholder="Enter your full name" />
        </Field>

        <Field label="Email Address">
            <Input type="email" placeholder="your.email@example.com" />
        </Field>

        <div class="flex items-center space-x-2 pt-2">
            <input 
                type="checkbox" 
                id="privacy" 
                class="h-4 w-4 rounded border-neutral-300 text-blue-600 focus:ring-blue-500 focus:ring-offset-0"
            />
            <label for="privacy" class="text-sm text-muted-foreground">
                I agree to receive promotional emails and accept the privacy policy
            </label>
        </div>

        <div class="pt-2">
            <Button clr="primary" full>
                Sign Up for Newsletter
            </Button>
        </div>
    </form>

    <div class="flex items-center justify-center space-x-4 pt-2 border-t border-neutral-200">
        <div class="flex items-center space-x-2 text-xs text-muted-foreground">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            <span>Privacy Protected</span>
        </div>
        <div class="flex items-center space-x-2 text-xs text-muted-foreground">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Unsubscribe Anytime</span>
        </div>
    </div>
</BentoCard>
