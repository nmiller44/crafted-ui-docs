---
import { classNames } from "@utils/classNames"
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<'fieldset'>{
    className?: string;
}

const { 
    className,
    ...props
 } = Astro.props;
---
<fieldset class={classNames("flex flex-col space-y-8", className)} {...props}>
    <slot />
</fieldset>