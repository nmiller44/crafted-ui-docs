---
import { classNames } from "@utils/classNames"
import CardHeader from "@components/card/CardHeader.astro";

interface Props {
    title?: string;
    subtitle?: string;
    className?: string;
    body?: boolean;
}

const { title, subtitle, className, body = false } = Astro.props;
---
<div class={classNames( 
                "flex flex-col",
                "rounded-md border border-border bg-card text-card-foreground shadow",
                body ? "px-8 py-10 space-y-6" : "",
                className)}>
    {
        !!title &&
            <CardHeader title={title} subtitle={subtitle} />
    }
    <slot />
</div>