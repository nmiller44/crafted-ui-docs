---
import { classNames } from "@utils/classNames"
import CardHeader from "@components/card/CardHeader.astro";

interface Props {
    title?: string;
    subtitle?: string;
    className?: string;
    body?: boolean;
    full?: boolean;
}

const { title, subtitle, className, body = false, full = false } = Astro.props;
---
<div class={classNames( 
                "flex flex-col",
                "bg-card text-card-foreground",
                full    ? "md:rounded-md md:border md:border-border md:shadow"
                        : "rounded-md border border-border shadow",
                className)}>
    {
        !!title &&
            <CardHeader title={title} subtitle={subtitle} />
    }
    <div class={classNames(
                "space-y-6",
                body    ? full ? "p-0 md:px-8 md:py-10" :  "px-8 py-10"
                        : ""
            )}>
        <slot />
    </div>
</div>